# Server-only environment variables (do NOT prefix with NEXT_PUBLIC_)
# Hugging Face API key (required)
HF_API_KEY=

# Hugging Face model name (required)
# Example: meta-llama/Llama-3.1-8B-Instruct
HF_MODEL_NAME=

# Optional generation controls
HF_TEMPERATURE=0.2
HF_MAX_TOKENS=512

# Optional: override Hugging Face router base URL
# Default: https://router.huggingface.co/v1
HF_BASE_URL=

# Optional: Hugging Face retry/model-loading controls (useful for AWS Lambda/API Gateway time budgets)
# Reduce these if you see API Gateway 502/504 due to timeouts.
HF_MAX_RETRIES=3
HF_WAIT_FOR_MODEL_MAX_MS=25000

# Optional request timeout (ms)
ANALYZE_TIMEOUT_MS=30000

# Optional: proxy analyze requests to an upstream API instead of calling Hugging Face directly.
# Example (AWS API Gateway / Lambda): https://xxxx.execute-api.us-east-1.amazonaws.com/prod/analyze
# When set, `POST /api/analyze` forwards the request to this URL.
ANALYZE_API_URL=

# Optional: Redis caching for /api/analyze (recommended in production)
# Local (docker-compose): redis://localhost:6379/0
# Prod: use a managed Redis (e.g., Upstash/Redis Cloud) and set its connection URL.
REDIS_URL=

# Optional: enable/disable caching (defaults to enabled when REDIS_URL is set)
ANALYZE_CACHE_ENABLED=1

# Optional: cache TTL in seconds (default: 86400 = 24 hours)
ANALYZE_CACHE_TTL_SECONDS=86400
