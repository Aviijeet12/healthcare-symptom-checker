# Production environment variables for AWS Lambda deployment
# Copy this to .env and fill in your real values before running: npx sst deploy

# REQUIRED — Your Hugging Face Inference API key
HF_API_KEY=hf_YOUR_KEY_HERE

# REQUIRED — Primary model
HF_MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# FALLBACK — If primary fails
HF_FALLBACK_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Tuning
HF_TEMPERATURE=0.1
HF_MAX_TOKENS=1024
HF_WAIT_FOR_MODEL_MAX_MS=15000
ANALYZE_TIMEOUT_MS=25000
